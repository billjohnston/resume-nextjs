{
  "name": "resume-monorepo",
  "version": "0.1.0",
  "private": true,
  "packageManager": "bun@1.1.22",
  "workspaces": [
    "apps/*",
    "infra"
  ],
  "scripts": {
    "dev": "bun --cwd apps/web run dev",
    "build": "bun --cwd apps/web run build",
    "start": "bun --cwd apps/web run start",
    "export": "bun --cwd apps/web run export",
    "deploy:cdk": "bun run --filter @resume/web build && bun run --filter @resume/infra cdk deploy -- --profile cdk --context stage=production"
  },
  "dependencies": {
    "zod": "^4.1.11"
  }
}
